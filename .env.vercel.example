# Copy these keys into Vercel -> Project -> Settings -> Environment Variables
# Replace values with your real provider values.

# 1) Use the pooled/pgbouncer connection string from your DB provider (Neon/Supabase/Railway).
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST/DBNAME?pgbouncer=true&connect_timeout=15"

# 2) Use the direct (non-pooled) connection string from your DB provider.
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST/DBNAME"

# 3) Public booking URL used for the CTA button.
NEXT_PUBLIC_BOOKING_URL="https://cal.com/your-handle/intro-call"

# 4) Optional booking embed URL for iframe on final screen.
NEXT_PUBLIC_BOOKING_EMBED_URL=""
